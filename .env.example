# Core
LOG_LEVEL=INFO
PROMETHEUS_METRICS_PATH=/metrics

# Security
# Set a strong token in production.
API_AUTH_TOKEN=change-me
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ALGORITHM=HS256

# Celery / Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_ALWAYS_EAGER=false
WORKER_CONCURRENCY=4
SCHEDULER_POLL_INTERVAL_SECONDS=30

# Request defaults
DEFAULT_REQUEST_TIMEOUT=10
DEFAULT_LATENCY_MS_THRESHOLD=1500

# Alerts
RESULT_WEBHOOK_URL=

# Observability
SENTRY_DSN=

# Optional persistence (future Postgres integration)
DATABASE_URL=postgresql+psycopg2://watchtower:watchtower@db:5432/watchtower
AUTO_CREATE_DB=false

# Frontend / NextAuth (loaded by docker-compose into the frontend + app services)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_ID=
GITHUB_SECRET=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3001

# Rate limiter Redis DB
RATE_LIMIT_REDIS_URL=redis://redis:6379/3
